    flex-direction: column;
    gap: 2.5rem;
  }

  .landing-experience-item {
    padding-bottom: 2rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .landing-experience-item:last-child {
    border-bottom: none;
  }

      /* Таймлайн стили */
