---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import Footer from '../components/Footer.astro';

const title = "Екатерина Ушакова — эксперт по технической документации и управлению знаниями";
const description = "Ex-руководитель редакций Ozon и Яндекса. Помогаю компаниям превращать хаос знаний в понятные процессы и документацию. Консалтинг, менторство и аудиты.";
---

<BaseLayout title={title} description={description}>
  <LandingHero
    title="Екатерина Ушакова"
    description="Ex-руководитель редакций Ozon и Яндекса. Помогаю компаниям превращать хаос знаний в понятные процессы и документацию"
