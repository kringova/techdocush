---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "У нас уже есть база знаний и кто-то иногда пишет документы — нужен ли аудит?",
    answer: "Чаще всего именно в таких компаниях больше всего скрытых проблем. Обычно знания сосредоточены в головах 2–3 человек, а поиск информации занимает часы. Аудит помогает увидеть это со стороны и понять, что можно улучшить быстро и без больших затрат."
  },
  {
    question: "Вы сами пишете документацию за команду?",
    answer: "Нет, моя задача — настроить процессы так, чтобы команда писала сама, а документация оставалась живой и после моего ухода. Если нужно именно написание большого объёма «под ключ» — помогу найти исполнителя."
  },
  {
    question: "Можно взять только аудит без дальнейшего сопровождения?",
    answer: "Конечно. Кто-то так и делает: получает карту проблем, рекомендации и внедряют сами."
  },
  {
    question: "А если команда маленькая, 5–15 человек?",
    answer: "Для небольших команд обычно достаточно «лёгкого» аудита или индивидуальной работы с одним‑двумя техписами. Подбираем формат под ваш размер и задачи."
  },
  {
    question: "Сколько времени от меня (руководителя) потребуется?",
    answer: "Обычно 2–4 часа на стартовые интервью + примерно час в месяц на обратную связь. Всё остальное я беру на себя."
  },
  {
    question: "Работаете ли с компаниями из других стран?",
    answer: "Да, работаю и с российскими, и с зарубежными командами. Всё официально: договор, NDA, удобная вам форма оплаты."
  },
  {
    question: "Можно оплатить частями?",
    answer: "Да, почти всегда разбиваем оплату на 2–3 этапа или помесячно — как вам комфортнее."
  },
  {
    question: "А если мы поймём, что не сработались?",
    answer: "В первые 14 дней после старта — полный возврат денег без вопросов."
  },
  {
    question: "Конфиденциальность",
    answer: "Подписываю NDA до первого серьёзного разговора. Никакие детали проектов не публикую без вашего явного согласия."
  },
  {
    question: "Можно сначала просто познакомиться и поговорить 15–20 минут?",
    answer: "Обязательно. На каждой услуге есть кнопка на бесплатный короткий созвон — ни к чему не обязывает."
  },
  {
    question: "Работаете ли по тендерам и госзакупкам?",
    answer: "К сожалению, нет — слишком много бюрократии."
  },
  {
    question: "Я обычный техпис/редактор, хочу расти — с чего лучше начать?",
    answer: "Самый простой старт — бесплатные 30 минут или диагностика 90 минут."
  }
];
